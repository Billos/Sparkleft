{
  "name": "sparkleft",
  "version": "2.24.0",
  "description": "Budget management assistant integrating with Firefly III. Automatically categorises transactions, manages budgets, and sends notifications via Discord or Gotify.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Billos/Sparkleft.git"
  },
  "license": "GPL-3.0-only",
  "author": "billos",
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "dev:server": "yarn dev:server:raw | pino-pretty -c",
    "dev:server:raw": "tsx watch --clear-screen=false src/server.ts",
    "dev:worker": "yarn dev:worker:raw | pino-pretty -c",
    "dev:worker:raw": "tsx watch --clear-screen=false src/worker.ts",
    "docker:build": "docker build --no-cache . -t billos/sparkleft:latest",
    "format": "prettier . --write",
    "format-check": "prettier . --check",
    "lint": "eslint src",
    "release": "semantic-release",
    "start:server": "node build/server.js | pino-pretty -c",
    "start:worker": "node build/worker.js | pino-pretty -c",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --build --dry",
    "types:api:generate": "openapi-ts"
  },
  "dependencies": {
    "@billos/firefly-iii-sdk": "6.5.5-sdk.2",
    "axios": "^1.7.9",
    "bullmq": "^5.56.0",
    "express": "^5.1.0",
    "luxon": "^3.5.0",
    "nunjucks": "^3.2.4",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@codedependant/semantic-release-docker": "^5.0.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/express": "^5.0.3",
    "@types/luxon": "^3.4.2",
    "@types/nunjucks": "^3.2.6",
    "@types/pug": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.15.0",
    "prettier": "^3.6.0",
    "prettier-plugin-multiline-arrays": "^4.0.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.6",
    "semantic-release": "^24.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
