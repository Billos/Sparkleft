{
  "name": "sparkleft",
  "version": "3.0.0",
  "description": "Budget management assistant integrating with Firefly III. Automatically categorises transactions, manages budgets, and sends notifications via Discord or Gotify.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Billos/Sparkleft.git"
  },
  "license": "GPL-3.0-only",
  "author": "billos",
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "build:frontend": "vite build",
    "clean": "rm -rf build node_modules",
    "dev:frontend": "vite",
    "dev:server": "yarn dev:server:raw | pino-pretty -c",
    "dev:server:raw": "tsx watch --clear-screen=false --include 'src/**/*.ts' src/server.ts",
    "dev:worker": "yarn dev:worker:raw | pino-pretty -c",
    "dev:worker:raw": "tsx watch --clear-screen=false --include 'src/**/*.ts' src/worker.ts",
    "docker:build": "docker build --no-cache . -t billos/sparkleft:latest",
    "format": "prettier . --write",
    "format-check": "prettier . --check",
    "lint": "oxlint src",
    "release": "semantic-release",
    "start:server": "node build/server.js | pino-pretty -c",
    "start:worker": "node build/worker.js | pino-pretty -c",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --build --dry",
    "types:api:generate": "openapi-ts",
    "vitest:ui": "vitest --ui"
  },
  "dependencies": {
    "@billos/firefly-iii-sdk": "6.5.5-sdk.6",
    "@js-temporal/polyfill": "^0.5.1",
    "bullmq": "^5.77.6",
    "express": "^5.1.0",
    "ioredis": "5.10.1",
    "nunjucks": "^3.2.4",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@codedependant/semantic-release-docker": "^5.0.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "^5.0.3",
    "@types/nunjucks": "^3.2.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.1.9",
    "oxlint": "^1.71.0",
    "prettier": "^3.6.0",
    "prettier-plugin-multiline-arrays": "^4.0.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.6",
    "semantic-release": "^24.2.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.0",
    "vite": "^8.1.2",
    "vitest": "^4.0.18",
    "vue": "^3.5.39",
    "vue-i18n": "11"
  },
  "packageManager": "yarn@4.14.1"
}
