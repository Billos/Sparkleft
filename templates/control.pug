doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Control UI – Sparkleft
    link(rel="icon" type="image/svg+xml" href="/public/favicon.png")
    link(rel="stylesheet" href="/public/style.css")
  body
    .container
      h1 Control UI
      .subtitle Trigger Sparkleft control jobs
      if version
        .version v#{version}
      .items
        h2 Auto Import
        button.control-button(type="button", data-token=token, data-action="autoimport", data-status-id="auto-import-status") Trigger Auto Import
        .status-message#auto-import-status
          span.status-icon
          span.status-text
      .items
        h2 Budget Sum Up
        button.control-button(type="button", data-token=token, data-action="budget-sumup", data-status-id="budget-sumup-status") Trigger Budget Sum Up
        .status-message#budget-sumup-status
          span.status-icon
          span.status-text
    .container
      h1 Hide Toggle Budgets
      .items
        if budgets && budgets.length > 0
          each budget in budgets
            - const budgetName = budget.attributes && budget.attributes.name
            - const isHidden = budgetName && hiddenBudgets && hiddenBudgets.includes(budgetName)
            button.toggle-button(
              type="button",
              data-token=token,
              data-type="budget",
              data-name=budgetName,
              class=isHidden ? "hidden-item" : "visible-item"
            )= budgetName + (isHidden ? " 🙈" : " 👁️")
        else
          p No budgets available
    .container
      h1 Budget Roles
      .subtitle Choose which budgets act as the Bills and Leftovers budgets
      .items
        if budgets && budgets.length > 0
          - const roles = [{ key: "bills", label: "Bills", selectedId: billsBudgetId }, { key: "leftovers", label: "Leftovers", selectedId: leftoversBudgetId }]
          each role in roles
            .role-row
              span.role-name= role.label
              each budget in budgets
                - const roleBudgetName = budget.attributes && budget.attributes.name
                - const isSelected = budget.id === role.selectedId
                button.role-button(
                  type="button",
                  data-token=token,
                  data-role=role.key,
                  data-budget-id=budget.id,
                  class=isSelected ? "selected-item" : "unselected-item"
                )= roleBudgetName + (isSelected ? " ✅" : "")
        else
          p No budgets available
    .container
      h1 Hide Toggle Categories
      .items
        if categories && categories.length > 0
          each category in categories
            - const categoryName = category.attributes && category.attributes.name
            - const isHidden = categoryName && hiddenCategories && hiddenCategories.includes(categoryName)
            button.toggle-button(
              type="button",
              data-token=token,
              data-type="category",
              data-name=categoryName,
              class=isHidden ? "hidden-item" : "visible-item"
            )= categoryName + (isHidden ? " 🙈" : " 👁️")
        else
          p No categories available
      script.
        const actionEndpoints = {
          autoimport: '/autoimport',
          'budget-sumup': '/budget-sumup',
        }
        const controlButtons = document.querySelectorAll('.control-button')

        controlButtons.forEach((btn) => {
          btn.addEventListener('click', async () => {
            const action = btn.dataset.action
            const statusId = btn.dataset.statusId
            const status = document.getElementById(statusId)
            if (!status) {
              console.error('Missing status element for control button:', statusId)
              return
            }
            try {
              await triggerAction(action, btn, status)
            } catch (e) {
              const statusIcon = status.querySelector('.status-icon')
              const statusText = status.querySelector('.status-text')
              statusIcon.textContent = '❌'
              statusText.textContent = 'An error occurred'
              status.className = 'status-message error visible'
              btn.disabled = false
              console.error('Control action failed:', e)
            }
          })
        })

        async function triggerAction(action, btn, status) {
          const statusIcon = status.querySelector('.status-icon')
          const statusText = status.querySelector('.status-text')
          const token = btn.getAttribute('data-token')
          const defaultLabel = btn.textContent
          const endpoint = actionEndpoints[action]

          if (!endpoint) {
            statusIcon.textContent = '❌'
            statusText.textContent = 'Invalid action'
            status.className = 'status-message error visible'
            return
          }

          btn.disabled = true
          btn.textContent = 'Running…'
          statusText.textContent = ''

          try {
            const params = new URLSearchParams({ api_token: token })
            const res = await fetch(endpoint + '?' + params.toString(), { method: 'POST' })
            const data = await res.json()
            if (res.ok) {
              statusIcon.textContent = '✅'
              status.className = 'status-message success visible'
            } else {
              statusIcon.textContent = '❌'
              status.className = 'status-message error visible'
            }
            statusText.textContent = data.message
          } catch (e) {
            statusIcon.textContent = '❌'
            statusText.textContent = 'An error occurred'
            status.className = 'status-message error visible'
          } finally {
            btn.disabled = false
            btn.textContent = defaultLabel
          }
        }

	
        const toggleButtons = document.querySelectorAll('.toggle-button')
        toggleButtons.forEach((btn) => {
          btn.addEventListener('click', async () => {
            const token = btn.getAttribute('data-token')
            const type = btn.getAttribute('data-type')
            const name = btn.getAttribute('data-name')
            if (type !== 'budget' && type !== 'category') {
              console.error('Invalid toggle type:', type)
              return
            }
            btn.disabled = true
            try {
              const params = new URLSearchParams({ api_token: token })
              const res = await fetch(`/hide-toggle/${type}/${encodeURIComponent(name)}?` + params.toString())
              if (!res.ok) {
                console.error('Hide toggle failed with status:', res.status)
                return
              }
              const data = await res.json()
              if (data.hidden) {
                btn.textContent = name + ' 🙈'
                btn.classList.remove('visible-item')
                btn.classList.add('hidden-item')
              } else {
                btn.textContent = name + ' 👁️'
                btn.classList.remove('hidden-item')
                btn.classList.add('visible-item')
              }
            } catch (e) {
              console.error('Hide toggle failed:', e)
            } finally {
              btn.disabled = false
              console.log('Reloading page to reflect changes...')
              window.location.reload()
            }
          })
        })

        const roleButtons = document.querySelectorAll('.role-button')
        roleButtons.forEach((btn) => {
          btn.addEventListener('click', async () => {
            const token = btn.getAttribute('data-token')
            const role = btn.getAttribute('data-role')
            const budgetId = btn.getAttribute('data-budget-id')
            if (role !== 'bills' && role !== 'leftovers') {
              console.error('Invalid budget role:', role)
              return
            }
            btn.disabled = true
            try {
              const params = new URLSearchParams({ api_token: token })
              const res = await fetch(`/config/budget-role/${role}/${encodeURIComponent(budgetId)}?` + params.toString(), {
                method: 'POST',
              })
              if (!res.ok) {
                console.error('Set budget role failed with status:', res.status)
                return
              }
            } catch (e) {
              console.error('Set budget role failed:', e)
            } finally {
              btn.disabled = false
              console.log('Reloading page to reflect changes...')
              window.location.reload()
            }
          })
        })