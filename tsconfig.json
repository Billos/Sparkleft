{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "build",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "esModuleInterop": true,
    // "strict": true,
    "allowJs": true,
    "lib": ["ES2023", "DOM"],
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@firefly": ["./src/sdk/firefly/index.ts"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "src/**/*.test.ts",
    "vitest.config.ts"
  ],
  "references": [
    { "path": "./tsconfig.gen.json" }]
}
